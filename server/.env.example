# Environment switch: development | production
# Change this to "production" when deploying
APP_ENV=development

# Server Port
PORT_DEV=3000
PORT_PROD=3000

# Database URLs
DATABASE_URL_DEV=postgresql://postgres:password@localhost:5432/social_network_local
DATABASE_URL_PROD=postgresql://user:password@production-host:5432/social_network_prod

# Redis URLs
REDIS_URL_DEV=redis://:password@localhost:6379
REDIS_URL_PROD=redis://:password@production-host:6379

# Frontend URLs (comma-separated for multiple origins)
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://your-frontend-domain.com

# Backend URLs
BACKEND_URL_DEV=http://localhost:3000
BACKEND_URL_PROD=https://your-api-domain.com

# ImageKit
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Auth
JWT_EXPIRES_IN=5m
JWT_SECRET=your_jwt_secret_change_this
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_SECRET=your_refresh_secret_change_this

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_price_id
STRIPE_PRO_PRICE_CENTS=999
STRIPE_PRO_CURRENCY=usd
STRIPE_TEST_TRIAL_SECONDS=0
# Note: STRIPE_SUCCESS_URL and STRIPE_CANCEL_URL are auto-generated from FRONTEND_URL
# They will be: {FRONTEND_URL}/billing/success and {FRONTEND_URL}/billing/cancel
# Override only if you need custom URLs:
# STRIPE_SUCCESS_URL_DEV=http://localhost:5173/custom/success
# STRIPE_SUCCESS_URL_PROD=https://your-frontend-domain.com/custom/success
# STRIPE_CANCEL_URL_DEV=http://localhost:5173/custom/cancel
# STRIPE_CANCEL_URL_PROD=https://your-frontend-domain.com/custom/cancel

# Cache
CACHE_ENABLED=true
