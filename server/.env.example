# Environment switch: development | production
APP_ENV=development

# Server Port
PORT=3000

# Database URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/social_network_local

# Redis URL
REDIS_URL=redis://:password@localhost:6379

# Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173

# Backend URL
BACKEND_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Auth
JWT_EXPIRES_IN=5m
JWT_SECRET=your_jwt_secret_change_this
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_SECRET=your_refresh_secret_change_this

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_price_id
STRIPE_PRO_PRICE_CENTS=999
STRIPE_PRO_CURRENCY=usd
STRIPE_TEST_TRIAL_SECONDS=0
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel

# Cache
CACHE_ENABLED=true
